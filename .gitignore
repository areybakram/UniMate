# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env

# typescript
*.tsbuildinfo

app-example

# Android build artifacts (C++ / Gradle / CMake caches - never commit these)
frontend/android/app/.cxx/
frontend/android/app/build/
frontend/android/.gradle/
frontend/android/build/
frontend/android/local.properties

# iOS build artifacts
frontend/ios/build/
frontend/ios/Pods/
frontend/ios/DerivedData/
